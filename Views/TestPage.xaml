<!-- IngilizceProje/MAUIClient/Views/TestPage.xaml -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:IngilizceProjeMAUI.ViewModels"
             xmlns:converters="clr-namespace:IngilizceProjeMAUI.Converters"
             x:Class="IngilizceProjeMAUI.Views.TestPage"
             Title="Çoktan Seçmeli Test"
             Background="{AppThemeBinding Light={StaticResource LightBgGradient}, Dark={StaticResource DarkBgGradient}}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:BoolToValueConverter x:Key="BoolToValueConverter" />
            <Color x:Key="CardColor">#CC1E293B</Color>
            <Color x:Key="TextColor">#F8FAFC</Color>
            <Color x:Key="BorderColor">#312E81</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*, Auto" Padding="20" RowSpacing="15">
        
        <!-- Main Quiz Area -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="16" MaximumWidthRequest="500" HorizontalOptions="Fill" VerticalOptions="CenterAndExpand">
                
                <!-- If no test loaded -->
                <VerticalStackLayout Spacing="15" IsVisible="{Binding HasTest, Converter={StaticResource BoolToValueConverter}, ConverterParameter='False|True'}" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="Çoktan Seçmeli Test" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}" HorizontalOptions="Center"/>
                    <Label Text="{Binding InfoMessage}" FontSize="14" TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    <Button Text="Yeniden Dene / Yükle 🔄" Command="{Binding LoadTestCommand}"
                            Background="{StaticResource PrimaryGradient}" TextColor="White" HeightRequest="45" CornerRadius="10" HorizontalOptions="Center" Margin="0,10,0,0"/>
                </VerticalStackLayout>

                <!-- Active Test Card -->
                <VerticalStackLayout Spacing="20" IsVisible="{Binding HasTest}">
                    
                    <!-- Feedback Banner -->
                    <Border IsVisible="{Binding IsAnswered}" 
                            BackgroundColor="{Binding IsCorrect, Converter={StaticResource BoolToValueConverter}, ConverterParameter='#064E3B|#7F1D1D'}" 
                            Stroke="{Binding IsCorrect, Converter={StaticResource BoolToValueConverter}, ConverterParameter='#10B981|#EF4444'}" 
                            StrokeThickness="1.5" StrokeShape="RoundRectangle 12" Padding="14">
                        <Label Text="{Binding FeedbackText}" FontSize="15" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </Border>

                    <!-- Question Container -->
                    <Border BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource CardColor}}" Stroke="{AppThemeBinding Light=#CBD5E1, Dark={StaticResource BorderColor}}" StrokeThickness="1.5" StrokeShape="RoundRectangle 20" Padding="24">
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,6" Radius="12" Opacity="{AppThemeBinding Light=0.08, Dark=0.3}"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="15">
                            <Label Text="İNGİLİZCE KELİME" FontSize="11" FontAttributes="Bold" TextColor="#6366F1" CharacterSpacing="2"/>
                            <Label Text="{Binding CurrentTest.EnglishWord}" FontSize="32" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark={StaticResource TextColor}}"/>
                            
                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#CBD5E1, Dark={StaticResource BorderColor}}"/>

                            <Label Text="ÖRNEK CÜMLE İÇİNDE KULLANIMI" FontSize="11" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" CharacterSpacing="1"/>
                            <Label Text="{Binding CurrentTest.ExampleSentence}" FontSize="15" TextColor="{AppThemeBinding Light=#1E293B, Dark={StaticResource TextColor}}" FontAttributes="Italic"/>
                            <Label Text="{Binding CurrentTest.ExampleSentenceTranslation}" FontSize="13" TextColor="{AppThemeBinding Light=#334155, Dark=#CBD5E1}" IsVisible="{Binding IsAnswered}"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Options Buttons Stack -->
                    <VerticalStackLayout Spacing="10">
                        <!-- Option A -->
                        <Button Text="{Binding OptionA}" Command="{Binding SelectOptionCommand}" CommandParameter="{Binding OptionA}"
                                BackgroundColor="{Binding OptionAColor}" BorderColor="{StaticResource BorderColor}" BorderWidth="1.5" TextColor="White" FontAttributes="Bold" HeightRequest="52" CornerRadius="12"/>

                        <!-- Option B -->
                        <Button Text="{Binding OptionB}" Command="{Binding SelectOptionCommand}" CommandParameter="{Binding OptionB}"
                                BackgroundColor="{Binding OptionBColor}" BorderColor="{StaticResource BorderColor}" BorderWidth="1.5" TextColor="White" FontAttributes="Bold" HeightRequest="52" CornerRadius="12"/>

                        <!-- Option C -->
                        <Button Text="{Binding OptionC}" Command="{Binding SelectOptionCommand}" CommandParameter="{Binding OptionC}"
                                BackgroundColor="{Binding OptionCColor}" BorderColor="{StaticResource BorderColor}" BorderWidth="1.5" TextColor="White" FontAttributes="Bold" HeightRequest="52" CornerRadius="12"/>

                        <!-- Option D -->
                        <Button Text="{Binding OptionD}" Command="{Binding SelectOptionCommand}" CommandParameter="{Binding OptionD}"
                                BackgroundColor="{Binding OptionDColor}" BorderColor="{StaticResource BorderColor}" BorderWidth="1.5" TextColor="White" FontAttributes="Bold" HeightRequest="52" CornerRadius="12"/>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Action Area (Sıradaki Soru) -->
        <VerticalStackLayout Grid.Row="1" Spacing="10">
            <Button Text="Sıradaki Soru ➡️" Command="{Binding LoadTestCommand}" IsVisible="{Binding IsAnswered}"
                    Background="{StaticResource SuccessGradient}" TextColor="White" FontAttributes="Bold" HeightRequest="50" CornerRadius="10"/>
            <ActivityIndicator IsRunning="{Binding IsBusy}" Color="#6366F1" HorizontalOptions="Center" HeightRequest="30"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
