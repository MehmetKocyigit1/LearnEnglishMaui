<!-- IngilizceProje/MAUIClient/Views/StatsAndGoalPage.xaml -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:IngilizceProjeMAUI.ViewModels"
             xmlns:converters="clr-namespace:IngilizceProjeMAUI.Converters"
             x:Class="IngilizceProjeMAUI.Views.StatsAndGoalPage"
             Title="İstatistikler ve Hedefler"
             Background="{AppThemeBinding Light=White, Dark={StaticResource DarkBgGradient}}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:BoolToValueConverter x:Key="BoolToValueConverter" />
            <Color x:Key="CardColor">#CC1E293B</Color>
            <Color x:Key="BorderColor">#312E81</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20" MaximumWidthRequest="500" HorizontalOptions="Fill">
            
            <!-- User Profile Header Card -->
            <Border BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource CardColor}}" Stroke="{AppThemeBinding Light=#CBD5E1, Dark={StaticResource BorderColor}}" StrokeThickness="1.5" StrokeShape="RoundRectangle 20" Padding="20" Margin="0,0,0,10">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,6" Radius="12" Opacity="{AppThemeBinding Light=0.08, Dark=0.3}"/>
                </Border.Shadow>
                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15" VerticalOptions="Center">
                    <Border Grid.Column="0" WidthRequest="60" HeightRequest="60" StrokeShape="RoundRectangle 30" BackgroundColor="{AppThemeBinding Light=#EEF2F6, Dark=#312E81}" StrokeThickness="0" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="👤" FontSize="30" TextColor="{AppThemeBinding Light=#4F46E5, Dark=White}" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                        <Label Text="{Binding UserName}" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}"/>
                        <Label Text="{Binding UserEmail}" FontSize="13" TextColor="{AppThemeBinding Light=#4F46E5, Dark=#C7D2FE}"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Statistics Summary Cards Grid -->
            <Label Text="Genel Performans" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}"/>
            
            <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" ColumnSpacing="12" RowSpacing="12">
                <!-- Total Words -->
                <Border Grid.Row="0" Grid.Column="0" BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource CardColor}}" Stroke="{AppThemeBinding Light=#CBD5E1, Dark={StaticResource BorderColor}}" StrokeThickness="1.5" StrokeShape="RoundRectangle 16" Padding="14">
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="8" Opacity="{AppThemeBinding Light=0.08, Dark=0.3}"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Toplam Kelime" FontSize="11" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}"/>
                        <Label Text="{Binding Statistics.TotalWords}" FontSize="24" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Success Rate -->
                <Border Grid.Row="0" Grid.Column="1" BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource CardColor}}" Stroke="{AppThemeBinding Light=#CBD5E1, Dark={StaticResource BorderColor}}" StrokeThickness="1.5" StrokeShape="RoundRectangle 16" Padding="14">
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="8" Opacity="{AppThemeBinding Light=0.08, Dark=0.3}"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Doğruluk Oranı" FontSize="11" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}"/>
                        <Label Text="{Binding Statistics.SuccessRate, StringFormat='%{0}'}" FontSize="24" FontAttributes="Bold" TextColor="#10B981"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Learning status counts -->
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource CardColor}}" Stroke="{AppThemeBinding Light=#CBD5E1, Dark={StaticResource BorderColor}}" StrokeThickness="1.5" StrokeShape="RoundRectangle 16" Padding="14">
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="8" Opacity="{AppThemeBinding Light=0.08, Dark=0.3}"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Öğrenme Seviyeleri" FontSize="11" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}"/>
                        <Grid ColumnDefinitions="*, *, *, *">
                            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                                <Label Text="{Binding Statistics.VeryImportantCount}" FontSize="18" FontAttributes="Bold" TextColor="#EF4444" HorizontalOptions="Center"/>
                                <Label Text="Önemli" FontSize="10" TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                                <Label Text="{Binding Statistics.NeedsReviewCount}" FontSize="18" FontAttributes="Bold" TextColor="#F59E0B" HorizontalOptions="Center"/>
                                <Label Text="Tekrar" FontSize="10" TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                                <Label Text="{Binding Statistics.LearnedCount}" FontSize="18" FontAttributes="Bold" TextColor="#10B981" HorizontalOptions="Center"/>
                                <Label Text="Öğrenilen" FontSize="10" TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center">
                                <Label Text="{Binding Statistics.NotReviewedCount}" FontSize="18" FontAttributes="Bold" TextColor="#6B7280" HorizontalOptions="Center"/>
                                <Label Text="Yeni" FontSize="10" TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Daily Goal Card -->
            <Label Text="Günlük Kelime Ekleme Hedefi" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}" Margin="0,10,0,0"/>
            
            <Border BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource CardColor}}" Stroke="{AppThemeBinding Light=#CBD5E1, Dark={StaticResource BorderColor}}" StrokeThickness="1.5" StrokeShape="RoundRectangle 20" Padding="20">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,6" Radius="12" Opacity="{AppThemeBinding Light=0.08, Dark=0.3}"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="Bugün Eklenen Kelimeler" FontSize="14" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}" VerticalOptions="Center"/>
                        <HorizontalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                            <Label Text="{Binding Statistics.DailyWordsAddedToday}" FontSize="18" FontAttributes="Bold" TextColor="#6366F1"/>
                            <Label Text="/" FontSize="16" TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" VerticalOptions="Center"/>
                            <Label Text="{Binding Statistics.DailyGoalTarget}" FontSize="16" TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Grid>

                    <!-- Progress bar -->
                    <ProgressBar Progress="{Binding Statistics.DailyGoalProgress, Converter={StaticResource BoolToValueConverter}, ConverterParameter='DivideBy100'}"
                                 ProgressColor="#6366F1" HeightRequest="8" Margin="0,5,0,5"/>

                    <Label Text="{Binding Statistics.DailyGoalProgress, StringFormat='Günlük hedefin %{0} kadarı tamamlandı!'}" FontSize="12" TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" HorizontalOptions="Center"/>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#CBD5E1, Dark={StaticResource BorderColor}}" Margin="0,5,0,5"/>

                    <!-- Set Daily Goal Form -->
                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="15" Margin="0,5,0,0" VerticalOptions="End">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Hedef Kelime Sayısı" FontSize="12" TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}"/>
                            <Border Stroke="{AppThemeBinding Light=#CBD5E1, Dark={StaticResource BorderColor}}" StrokeShape="RoundRectangle 8" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}" HeightRequest="45">
                                <Entry Text="{Binding TargetCount}" Keyboard="Numeric" TextColor="{AppThemeBinding Light=Black, Dark=White}" Margin="10,0" VerticalOptions="Center"/>
                            </Border>
                        </VerticalStackLayout>
                        <Button Grid.Column="1" Text="Güncelle 🔄" Command="{Binding SaveDailyGoalCommand}"
                                Background="{StaticResource PrimaryGradient}" TextColor="White" HeightRequest="45" CornerRadius="8" VerticalOptions="End" FontAttributes="Bold"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Reminder Notification Card -->
            <Label Text="Günlük Hatırlatıcı Bildirim" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}" Margin="0,10,0,0"/>

            <Border BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource CardColor}}" Stroke="{AppThemeBinding Light=#CBD5E1, Dark={StaticResource BorderColor}}" StrokeThickness="1.5" StrokeShape="RoundRectangle 20" Padding="20">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,6" Radius="12" Opacity="{AppThemeBinding Light=0.08, Dark=0.3}"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="15">
                    <Label Text="Her gün seçtiğiniz saatte kelime çalışmanız için bildirim alacaksınız." FontSize="13" TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}"/>

                    <Label Text="{Binding ReminderStatusText}" FontSize="14" FontAttributes="Bold" TextColor="#10B981" HorizontalOptions="Center"/>

                    <!-- Time picker and actions -->
                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="15" VerticalOptions="Center">
                        <Border Grid.Column="0" Stroke="{AppThemeBinding Light=#CBD5E1, Dark={StaticResource BorderColor}}" StrokeThickness="1.5" StrokeShape="RoundRectangle 8" BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}">
                            <TimePicker Time="{Binding ReminderTime}" TextColor="{AppThemeBinding Light=Black, Dark=White}" HeightRequest="40" Margin="5,0,5,0"/>
                        </Border>
                        <Button Grid.Column="1" Text="Saati Kaydet 🔔" Command="{Binding SaveReminderCommand}"
                                Background="{StaticResource SuccessGradient}" TextColor="White" HeightRequest="42" CornerRadius="8" VerticalOptions="Center" FontAttributes="Bold"/>
                    </Grid>

                    <Button Text="Hatırlatıcıyı Kapat 🔕" Command="{Binding DisableReminderCommand}"
                            Background="Transparent" TextColor="#EF4444" BorderColor="#EF4444" BorderWidth="1.5" HeightRequest="42" CornerRadius="8" Margin="0,5,0,0" FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator IsRunning="{Binding IsBusy}" Color="#6366F1" HorizontalOptions="Center" HeightRequest="30"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
