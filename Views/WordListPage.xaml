<!-- IngilizceProje/MAUIClient/Views/WordListPage.xaml -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:IngilizceProjeMAUI.ViewModels"
             xmlns:dto="clr-namespace:IngilizceProje.Application.DTOs;assembly=IngilizceProje.Application"
             xmlns:converters="clr-namespace:IngilizceProjeMAUI.Converters"
             x:Class="IngilizceProjeMAUI.Views.WordListPage"
             Title="Kelimelerim"
             Background="{AppThemeBinding Light=White, Dark={StaticResource DarkBgGradient}}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
            <converters:BoolToValueConverter x:Key="BoolToValueConverter" />
            <Color x:Key="CardColor">#CC1E293B</Color>
            <Color x:Key="TextColor">#F8FAFC</Color>
            <Color x:Key="BorderColor">#312E81</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, Auto, *, Auto" Padding="12" RowSpacing="10">
        <!-- Search and Actions Bar -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto" ColumnSpacing="8">
            <Border Grid.Column="0" Stroke="{AppThemeBinding Light=#CBD5E1, Dark={StaticResource BorderColor}}" StrokeShape="RoundRectangle 8" StrokeThickness="1.5" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E293B}" HeightRequest="45">
                <SearchBar Text="{Binding SearchQuery}" Placeholder="Kelime ara..." 
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#94A3B8}" BackgroundColor="Transparent" Margin="0"
                           SearchCommand="{Binding ApplyFiltersCommand}"/>
            </Border>
            <Button Grid.Column="1" Text="Excel 📊" Command="{Binding ExportExcelCommand}"
                    Background="{StaticResource SuccessGradient}" TextColor="White" HeightRequest="45" CornerRadius="8" FontAttributes="Bold"/>
            <Button Grid.Column="2" Text="CSV 📄" Command="{Binding ExportCsvCommand}"
                    Background="{StaticResource BlueGradient}" TextColor="White" HeightRequest="45" CornerRadius="8" FontAttributes="Bold"/>
        </Grid>

        <!-- Filters Bar -->
        <Grid Grid.Row="1" ColumnDefinitions="*, *" ColumnSpacing="8">
            <VerticalStackLayout Grid.Column="0" Spacing="4">
                <Label Text="Durum Filtresi" TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" FontSize="11" FontAttributes="Bold" Margin="2,0"/>
                <Border Stroke="{AppThemeBinding Light=#CBD5E1, Dark={StaticResource BorderColor}}" StrokeThickness="1.5" StrokeShape="RoundRectangle 8" Background="{AppThemeBinding Light=White, Dark=#1E293B}">
                    <Picker ItemsSource="{Binding StatusFilterOptions}" SelectedItem="{Binding SelectedStatusFilter}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" TitleColor="#94A3B8" HeightRequest="40"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" Spacing="4">
                <Label Text="Tür Filtresi" TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" FontSize="11" FontAttributes="Bold" Margin="2,0"/>
                <Border Stroke="{AppThemeBinding Light=#CBD5E1, Dark={StaticResource BorderColor}}" StrokeThickness="1.5" StrokeShape="RoundRectangle 8" Background="{AppThemeBinding Light=White, Dark=#1E293B}">
                    <Picker ItemsSource="{Binding TypeFilterOptions}" SelectedItem="{Binding SelectedTypeFilter}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" TitleColor="#94A3B8" HeightRequest="40"/>
                </Border>
            </VerticalStackLayout>
        </Grid>

        <!-- Words List Area -->
        <RefreshView Grid.Row="2" IsRefreshing="{Binding IsBusy}" Command="{Binding LoadWordsCommand}">
            <CollectionView ItemsSource="{Binding Words}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Padding="30">
                        <Label Text="Kelime Bulunamadı" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}" HorizontalOptions="Center"/>
                        <Label Text="Arama kriterlerinize uygun kelime yok veya listeniz boş." FontSize="14" TextColor="{AppThemeBinding Light=#475569, Dark=#94A3B8}" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="dto:WordDto">
                        <Border Margin="2,6,2,6" Background="{AppThemeBinding Light={StaticResource LightCardGradient}, Dark={StaticResource WordCardGradient}}" 
                                Stroke="{AppThemeBinding Light=#CBD5E1, Dark=#4F46E5}" StrokeThickness="1.2" StrokeShape="RoundRectangle 16" Padding="14">
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,4" Radius="10" Opacity="{AppThemeBinding Light=0.08, Dark=0.35}"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WordListViewModel}}, Path=NavigateToDetailsCommand}" CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12" VerticalOptions="Center">
                                <!-- Status Indicator Dot with white border glow -->
                                <Ellipse Grid.Column="0" WidthRequest="16" HeightRequest="16"
                                         Fill="{Binding LearningStatus, Converter={StaticResource StatusToColorConverter}}"
                                         Stroke="{AppThemeBinding Light=#CBD5E1, Dark=White}" StrokeThickness="1.5"
                                         VerticalOptions="Center" HorizontalOptions="Center"/>

                                <!-- Word Text Details -->
                                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding EnglishWord}" FontSize="19" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}"/>
                                        <!-- Word Type Badge -->
                                        <Border Background="{AppThemeBinding Light=#EEF2F6, Dark=#312E81}" Stroke="{AppThemeBinding Light=#CBD5E1, Dark=#4F46E5}" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="8,3" VerticalOptions="Center">
                                            <Label Text="{Binding WordType}" FontSize="10" TextColor="{AppThemeBinding Light=#4F46E5, Dark=#C7D2FE}" FontAttributes="Bold"/>
                                        </Border>
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding TurkishMeaning}" FontSize="14" TextColor="{AppThemeBinding Light=#4F46E5, Dark=#C7D2FE}"/>
                                </VerticalStackLayout>

                                <!-- Favorite Heart Icon -->
                                <Button Grid.Column="2" 
                                        Text="{Binding IsFavorite, Converter={StaticResource BoolToValueConverter}, ConverterParameter='♥|♡'}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WordListViewModel}}, Path=ToggleFavoriteCommand}"
                                        CommandParameter="{Binding .}"
                                        TextColor="{Binding IsFavorite, Converter={StaticResource BoolToValueConverter}, ConverterParameter='#EF4444|#94A3B8'}"
                                        FontSize="24"
                                        BackgroundColor="Transparent"
                                        WidthRequest="45"
                                        HeightRequest="45"
                                        Padding="0"
                                        VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Floating Add Word Button -->
        <Button Grid.Row="3" Text="+ Yeni Kelime Ekle" Command="{Binding NavigateToAddWordCommand}"
                Background="{StaticResource PrimaryGradient}" TextColor="White" FontAttributes="Bold" HeightRequest="50" CornerRadius="12" Margin="0,4,0,4"/>
    </Grid>
</ContentPage>
