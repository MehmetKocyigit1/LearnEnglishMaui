<!-- IngilizceProje/MAUIClient/Views/WordDetailPage.xaml -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:IngilizceProjeMAUI.ViewModels"
             xmlns:converters="clr-namespace:IngilizceProjeMAUI.Converters"
             x:Class="IngilizceProjeMAUI.Views.WordDetailPage"
             Title="Kelime Detayı"
             Background="{AppThemeBinding Light={StaticResource LightPageBg}, Dark={StaticResource DarkBgGradient}}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
            <converters:BoolToValueConverter x:Key="BoolToValueConverter" />
            <Color x:Key="CardColor">#CC1E293B</Color>
            <Color x:Key="TextColor">#F8FAFC</Color>
            <Color x:Key="BorderColor">#312E81</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="20" MaximumWidthRequest="500" HorizontalOptions="Fill">
            <!-- Word Primary Header Card -->
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightCardBg}, Dark={StaticResource CardColor}}" Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource BorderColor}}" 
                    StrokeThickness="1.5" StrokeShape="RoundRectangle 20" Padding="20">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,6" Radius="12" Opacity="{AppThemeBinding Light=0.06, Dark=0.3}"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*, Auto">
                        <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                            <Ellipse WidthRequest="16" HeightRequest="16"
                                     Fill="{Binding Word.LearningStatus, Converter={StaticResource StatusToColorConverter}}"/>
                            <Label Text="{Binding Word.WordType}" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource LightTextSecondary}, Dark=#94A3B8}" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <!-- Favorite Button -->
                        <Button Grid.Column="1" 
                                Text="{Binding Word.IsFavorite, Converter={StaticResource BoolToValueConverter}, ConverterParameter='♥|♡'}"
                                Command="{Binding ToggleFavoriteCommand}"
                                TextColor="{Binding Word.IsFavorite, Converter={StaticResource BoolToValueConverter}, ConverterParameter='#EF4444|#94A3B8'}"
                                FontSize="26"
                                BackgroundColor="Transparent"
                                WidthRequest="50"
                                HeightRequest="50"
                                Padding="0"
                                HorizontalOptions="End"/>
                    </Grid>

                    <Label Text="{Binding Word.EnglishWord}" FontSize="34" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource TextColor}}"/>
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource BorderColor}}"/>
                    <Label Text="Türkçe Anlamı" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource LightTextSecondary}, Dark=#94A3B8}"/>
                    <Label Text="{Binding Word.TurkishMeaning}" FontSize="22" FontAttributes="Bold" TextColor="#6366F1"/>
                </VerticalStackLayout>
            </Border>

            <!-- Example Sentence Card -->
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightCardBg}, Dark={StaticResource CardColor}}" Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource BorderColor}}" 
                    StrokeThickness="1.5" StrokeShape="RoundRectangle 20" Padding="20">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,6" Radius="12" Opacity="{AppThemeBinding Light=0.06, Dark=0.3}"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Örnek Cümle" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource LightTextSecondary}, Dark=#94A3B8}"/>
                    <Label Text="{Binding Word.ExampleSentence}" FontSize="16" TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource TextColor}}" FontAttributes="Italic"/>
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource BorderColor}}"/>
                    <Label Text="Çevirisi" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource LightTextSecondary}, Dark=#94A3B8}"/>
                    <Label Text="{Binding Word.ExampleSentenceTranslation}" FontSize="15" TextColor="{AppThemeBinding Light={StaticResource LightTextSecondary}, Dark=#CBD5E1}"/>
                </VerticalStackLayout>
            </Border>

            <!-- Statistics Card -->
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightCardBg}, Dark={StaticResource CardColor}}" Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource BorderColor}}" 
                    StrokeThickness="1.5" StrokeShape="RoundRectangle 20" Padding="20">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,6" Radius="12" Opacity="{AppThemeBinding Light=0.06, Dark=0.3}"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Çalışma İstatistikleri" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource LightTextSecondary}, Dark=#94A3B8}"/>
                    <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10" HorizontalOptions="Fill">
                        <!-- Total Reviews -->
                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4">
                            <Label Text="{Binding Word.ReviewCount}" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark=White}" HorizontalOptions="Center"/>
                            <Label Text="Tekrar" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource LightTextSecondary}, Dark=#94A3B8}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <!-- Correct Answers -->
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="4">
                            <Label Text="{Binding Word.CorrectAnswerCount}" FontSize="20" FontAttributes="Bold" TextColor="#10B981" HorizontalOptions="Center"/>
                            <Label Text="Doğru" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource LightTextSecondary}, Dark=#94A3B8}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <!-- Wrong Answers -->
                        <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="4">
                            <Label Text="{Binding Word.WrongAnswerCount}" FontSize="20" FontAttributes="Bold" TextColor="#EF4444" HorizontalOptions="Center"/>
                            <Label Text="Yanlış" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource LightTextSecondary}, Dark=#94A3B8}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Management Buttons -->
            <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                <Button Grid.Column="0" Text="Düzenle ✏️" Command="{Binding EditWordCommand}"
                        Background="{StaticResource BlueGradient}" TextColor="White" FontAttributes="Bold" HeightRequest="48" CornerRadius="10"/>
                <Button Grid.Column="1" Text="Sil 🗑️" Command="{Binding DeleteWordCommand}"
                        Background="{StaticResource DangerGradient}" TextColor="White" FontAttributes="Bold" HeightRequest="48" CornerRadius="10"/>
            </Grid>

            <ActivityIndicator IsRunning="{Binding IsBusy}" Color="#6366F1" HorizontalOptions="Center" HeightRequest="35"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
