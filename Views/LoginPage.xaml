<!-- IngilizceProje/MAUIClient/Views/LoginPage.xaml -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:IngilizceProjeMAUI.ViewModels"
             xmlns:converters="clr-namespace:IngilizceProjeMAUI.Converters"
             x:Class="IngilizceProjeMAUI.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             Background="{AppThemeBinding Light={StaticResource LightPageBg}, Dark={StaticResource DarkBgGradient}}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:BoolToValueConverter x:Key="KeyValueConverter" />
            <Color x:Key="PrimaryColor">#F8FAFC</Color>
            <Color x:Key="SecondaryColor">gray</Color>
            <Color x:Key="CardColor">#CC1E293B</Color>
            <Color x:Key="TextColor">black</Color>
            <Color x:Key="PlaceholderColor">#94A3B8</Color>
            <Color x:Key="BorderColor">#312E81</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <Grid RowDefinitions="Auto, *" VerticalOptions="FillAndExpand" Padding="20">
            <!-- Header Logo/Title Area -->
            <VerticalStackLayout Grid.Row="0" HorizontalOptions="Center" Spacing="10" Margin="0,40,0,30">
                <Border WidthRequest="80" HeightRequest="80" StrokeShape="RoundRectangle 24" 
                        Background="{StaticResource PrimaryGradient}" StrokeThickness="0">
                    <Label Text="A" FontSize="40" TextColor="White" FontAttributes="Bold"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
                <Label Text="Antigravity English" FontSize="28" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark=White}" HorizontalOptions="Center"/>
                <Label Text="Kelime Öğren ve Tekrar Et" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource LightTextSecondary}, Dark=#94A3B8}" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Card Body Area -->
            <Border Grid.Row="1" BackgroundColor="{AppThemeBinding Light={StaticResource LightCardBg}, Dark={StaticResource CardColor}}" StrokeShape="RoundRectangle 20"
                    Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource BorderColor}}" StrokeThickness="1.5" Padding="24" MaximumWidthRequest="450"
                    VerticalOptions="Center" HorizontalOptions="Fill">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,10" Radius="20" Opacity="{AppThemeBinding Light=0.08, Dark=0.4}" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="18">
                    <Label Text="{Binding IsRegisterMode, Converter={StaticResource KeyValueConverter}, ConverterParameter='Kayıt Ol|Giriş Yap'}" 
                           FontSize="22" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark=White}"/>

                    <!-- Error Message -->
                    <Label Text="{Binding ErrorMessage}" TextColor="#EF4444" FontSize="13" 
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource KeyValueConverter}, ConverterParameter='True|False'}"/>

                    <!-- UserName Field (only for register) -->
                    <VerticalStackLayout Spacing="6" IsVisible="{Binding IsRegisterMode}">
                        <Label Text="Kullanıcı Adı" TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark=White}" FontSize="14" FontAttributes="Bold"/>
                        <Border Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource BorderColor}}" StrokeShape="RoundRectangle 8" StrokeThickness="1.5" BackgroundColor="{AppThemeBinding Light={StaticResource LightInputBg}, Dark=#0F172A}" HeightRequest="46">
                            <Entry Text="{Binding UserName}" Placeholder="kullanici_adi" 
                                   TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark=White}" PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#64748B}"
                                   Margin="10,0" Keyboard="Text" VerticalOptions="Center"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Email Field -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="E-posta" TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark=White}" FontSize="14" FontAttributes="Bold"/>
                        <Border Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource BorderColor}}" StrokeShape="RoundRectangle 8" StrokeThickness="1.5" BackgroundColor="{AppThemeBinding Light={StaticResource LightInputBg}, Dark=#0F172A}" HeightRequest="46">
                            <Entry Text="{Binding Email}" Placeholder="eposta@adresiniz.com" 
                                   TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark=White}" PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#64748B}"
                                   Margin="10,0" Keyboard="Email" VerticalOptions="Center"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Password Field -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Şifre" TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark=White}" FontSize="14" FontAttributes="Bold"/>
                        <Border Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource BorderColor}}" StrokeShape="RoundRectangle 8" StrokeThickness="1.5" BackgroundColor="{AppThemeBinding Light={StaticResource LightInputBg}, Dark=#0F172A}" HeightRequest="46">
                            <Entry Text="{Binding Password}" Placeholder="••••••" IsPassword="True"
                                   TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark=White}" PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#64748B}"
                                   Margin="10,0" VerticalOptions="Center"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Action Button -->
                    <Button Text="{Binding IsRegisterMode, Converter={StaticResource KeyValueConverter}, ConverterParameter='Kayıt Ol|Giriş Yap'}" 
                            Command="{Binding AuthenticateCommand}"
                            Background="{StaticResource PrimaryGradient}" TextColor="White" FontAttributes="Bold" HeightRequest="48" CornerRadius="10"
                            Margin="0,10,0,0"/>

                    <!-- Activity Indicator -->
                    <ActivityIndicator IsRunning="{Binding IsBusy}" Color="#6366F1" HorizontalOptions="Center" HeightRequest="30"/>

                    <!-- Toggle Mode Link -->
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,10,0,0">
                        <Label Text="{Binding IsRegisterMode, Converter={StaticResource KeyValueConverter}, ConverterParameter='Hesabınız var mı?|Hesabınız yok mu?'}" 
                               TextColor="{StaticResource PlaceholderColor}" FontSize="14"/>
                        <Label Text="{Binding IsRegisterMode, Converter={StaticResource KeyValueConverter}, ConverterParameter='Giriş Yapın|Kayıt Olun'}" 
                               TextColor="#6366F1" FontSize="14" FontAttributes="Bold">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleModeCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>
