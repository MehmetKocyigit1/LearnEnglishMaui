<!-- IngilizceProje/MAUIClient/Views/AddWordPage.xaml -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:IngilizceProjeMAUI.ViewModels"
             xmlns:converters="clr-namespace:IngilizceProjeMAUI.Converters"
             x:Class="IngilizceProjeMAUI.Views.AddWordPage"
             Title="{Binding IsEditMode, Converter={StaticResource BoolToValueConverter}, ConverterParameter='Kelimeyi Düzenle|Yeni Kelime Ekle'}"
             Background="{AppThemeBinding Light=White, Dark={StaticResource DarkBgGradient}}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:BoolToValueConverter x:Key="BoolToValueConverter" />
            <Color x:Key="CardColor">#CC1E293B</Color>
            <Color x:Key="TextColor">#F8FAFC</Color>
            <Color x:Key="BorderColor">#312E81</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="16" MaximumWidthRequest="500" HorizontalOptions="Fill">
            
            <!-- Error Label -->
            <Label Text="{Binding ErrorMessage}" TextColor="#EF4444" FontSize="13" FontAttributes="Bold"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource BoolToValueConverter}, ConverterParameter='True|False'}"/>

            <!-- English Word Entry -->
            <VerticalStackLayout Spacing="6">
                <Label Text="İngilizce Kelime" TextColor="{AppThemeBinding Light=#0F172A, Dark={StaticResource TextColor}}" FontSize="14" FontAttributes="Bold"/>
                <Border Stroke="{AppThemeBinding Light=#CBD5E1, Dark={StaticResource BorderColor}}" StrokeShape="RoundRectangle 8" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1E293B}" HeightRequest="46">
                    <Entry Text="{Binding EnglishWord}" Placeholder="Örn: Serendipity" 
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#94A3B8}" Margin="10,0" VerticalOptions="Center"/>
                </Border>
            </VerticalStackLayout>

            <!-- Turkish Meaning Entry -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Türkçe Anlamı" TextColor="{AppThemeBinding Light=#0F172A, Dark={StaticResource TextColor}}" FontSize="14" FontAttributes="Bold"/>
                <Border Stroke="{AppThemeBinding Light=#CBD5E1, Dark={StaticResource BorderColor}}" StrokeShape="RoundRectangle 8" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1E293B}" HeightRequest="46">
                    <Entry Text="{Binding TurkishMeaning}" Placeholder="Örn: Tesadüfi güzellik" 
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#94A3B8}" Margin="10,0" VerticalOptions="Center"/>
                </Border>
            </VerticalStackLayout>

            <!-- Word Type Picker -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Kelime Türü" TextColor="{AppThemeBinding Light=#0F172A, Dark={StaticResource TextColor}}" FontSize="14" FontAttributes="Bold"/>
                <Border Stroke="{AppThemeBinding Light=#CBD5E1, Dark={StaticResource BorderColor}}" StrokeThickness="1" StrokeShape="RoundRectangle 8" Background="{AppThemeBinding Light=White, Dark=#1E293B}">
                    <Picker ItemsSource="{Binding WordTypes}" SelectedItem="{Binding SelectedWordType}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" TitleColor="#94A3B8" HeightRequest="40"/>
                </Border>
            </VerticalStackLayout>

            <!-- Example Sentence Entry -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Örnek Cümle" TextColor="{AppThemeBinding Light=#0F172A, Dark={StaticResource TextColor}}" FontSize="14" FontAttributes="Bold"/>
                <Border Stroke="{AppThemeBinding Light=#CBD5E1, Dark={StaticResource BorderColor}}" StrokeShape="RoundRectangle 8" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1E293B}" HeightRequest="86" Padding="5">
                    <Editor Text="{Binding ExampleSentence}" Placeholder="Örn: We found the cozy bookshop by serendipity." 
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#94A3B8}" BackgroundColor="Transparent"/>
                </Border>
            </VerticalStackLayout>

            <!-- Example Sentence Translation Entry -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Cümle Çevirisi" TextColor="{AppThemeBinding Light=#0F172A, Dark={StaticResource TextColor}}" FontSize="14" FontAttributes="Bold"/>
                <Border Stroke="{AppThemeBinding Light=#CBD5E1, Dark={StaticResource BorderColor}}" StrokeShape="RoundRectangle 8" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1E293B}" HeightRequest="86" Padding="5">
                    <Editor Text="{Binding ExampleSentenceTranslation}" Placeholder="Örn: Şirin kitapçıyı tesadüfen bulduk." 
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#94A3B8}" BackgroundColor="Transparent"/>
                </Border>
            </VerticalStackLayout>

            <!-- EDIT MODE ONLY FIELDS -->
            <VerticalStackLayout Spacing="16" IsVisible="{Binding IsEditMode}">
                <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#CBD5E1, Dark={StaticResource BorderColor}}"/>

                <!-- Learning Status Picker -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Öğrenme Durumu" TextColor="{AppThemeBinding Light=#0F172A, Dark={StaticResource TextColor}}" FontSize="14" FontAttributes="Bold"/>
                    <Border Stroke="{AppThemeBinding Light=#CBD5E1, Dark={StaticResource BorderColor}}" StrokeThickness="1" StrokeShape="RoundRectangle 8" Background="{AppThemeBinding Light=White, Dark=#1E293B}">
                        <Picker ItemsSource="{Binding LearningStatuses}" SelectedItem="{Binding LearningStatus}"
                                TextColor="{AppThemeBinding Light=Black, Dark=White}" TitleColor="#94A3B8" HeightRequest="40"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Is Favorite Switch -->
                <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center" HeightRequest="40">
                    <Label Grid.Column="0" Text="Favorilere Ekle" TextColor="{AppThemeBinding Light=#0F172A, Dark={StaticResource TextColor}}" FontSize="14" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Switch Grid.Column="1" IsToggled="{Binding IsFavorite}" ThumbColor="#6366F1" OnColor="{AppThemeBinding Light=#EEF2F6, Dark=#312E81}" VerticalOptions="Center"/>
                </Grid>
            </VerticalStackLayout>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,15,0,0">
                <Button Grid.Column="0" Text="İptal ❌" Command="{Binding CancelCommand}"
                        Background="{StaticResource DangerGradient}" TextColor="White" FontAttributes="Bold" HeightRequest="48" CornerRadius="10"/>
                <Button Grid.Column="1" Text="Kaydet 💾" Command="{Binding SaveCommand}"
                        Background="{StaticResource SuccessGradient}" TextColor="White" FontAttributes="Bold" HeightRequest="48" CornerRadius="10"/>
            </Grid>

            <ActivityIndicator IsRunning="{Binding IsBusy}" Color="#6366F1" HorizontalOptions="Center" HeightRequest="30"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
